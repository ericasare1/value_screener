        with col1:
            try:
                stock = yf.Ticker(ticker)
                price = stock.info.get("regularMarketPrice", "N/A")
                st.metric(f"**{ticker}**", f"${price:.2f}" if price != "N/A" else "N/A", delta="live")
            except:
                st.metric(f"**{ticker}**", "No data")
        with col2:
            try:
                hist = stock.history(period="1mo")
                if not hist.empty:
                    fig_price = px.line(hist.reset_index(), x="Date", y="Close", 
                                      title=f"{ticker} 1-Month Chart")
                    fig_price.update_layout(height=250, margin=dict(t=30))
                    st.plotly_chart(fig_price, use_container_width=True)
                else:
                    st.write("No chart data")
            except:
                st.write("Chart unavailable")

        st.metric("Portfolio Value", f"${total_val:,.0f}")
